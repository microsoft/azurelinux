{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/microsoft/azurelinux/base/tests/tee-tests.schema.json",
  "title": "TEE Test Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "testsuite": {
      "$ref": "#/$defs/TestSuite"
    },
    "selector": {
      "$ref": "#/$defs/Selector"
    },
    "image": {
      "$ref": "#/$defs/ImageRef"
    },
    "platform": {
      "$ref": "#/$defs/Platform"
    },
    "features": {
      "$ref": "#/$defs/Features"
    },
    "artifacts": {
      "$ref": "#/$defs/Artifacts"
    },
    "includes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "testsuite",
    "selector",
    "image"
  ],
  "$defs": {
    "TestSuite": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "OptionsField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "options": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "integer"
            ]
          }
        }
      },
      "required": [
        "options"
      ]
    },
    "Selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "area": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/OptionsField"
            }
          ]
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/OptionsField"
            }
          ]
        },
        "priority": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            {
              "$ref": "#/$defs/OptionsField"
            }
          ]
        },
        "tags": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "$ref": "#/$defs/OptionsField"
            }
          ]
        },
        "testcase_names": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "$ref": "#/$defs/OptionsField"
            }
          ]
        }
      }
    },
    "ImageRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "definition": {
          "type": "string"
        }
      },
      "required": [
        "definition"
      ]
    },
    "Platform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "location": {
          "type": "string"
        },
        "vm_size": {
          "type": "string"
        }
      }
    },
    "Features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          }
        }
      },
      "required": [
        "items"
      ]
    },
    "Artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}