-    }
-
-    @Override
-    public String getNdc() {
-        return ThreadContext.peek();
-    }
-
-    @Override
-    public int getNdcDepth() {
-        return ThreadContext.getDepth();
-    }
-
-    @Override
-    public String popNdc() {
