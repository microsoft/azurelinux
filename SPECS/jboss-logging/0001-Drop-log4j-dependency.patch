-    }
-
-    @Override
-    public String peekNdc() {
-        return ThreadContext.peek();
-    }
-
-    @Override
-    public void pushNdc(String message) {
-        ThreadContext.push(message);
-    }
-
-    @Override
-    public void setNdcMaxDepth(int maxDepth) {
-        ThreadContext.trim(maxDepth);
-    }
-}
