From d309da3166c1ab95506c9fabb678204ccd6670f3 Mon Sep 17 00:00:00 2001
From: Alberto Valverde <alberto@toscat.net>
Date: Fri, 26 Jul 2024 18:03:54 +0200
Subject: [PATCH 2/2] unbreak 64bit

---
 cborg/src/Codec/CBOR/Decoding.hs | 6 +++++-
 cborg/src/Codec/CBOR/Read.hs     | 8 ++++++++
 2 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/cborg/src/Codec/CBOR/Decoding.hs b/cborg/src/Codec/CBOR/Decoding.hs
index 8d78def..fbc82ac 100644
--- a/cborg/src/Codec/CBOR/Decoding.hs
+++ b/cborg/src/Codec/CBOR/Decoding.hs
@@ -962,7 +962,11 @@ type ByteOffset = Int64
 -- @since 0.2.2.0
 peekByteOffset :: Decoder s ByteOffset
 peekByteOffset = Decoder (\k -> return (PeekByteOffset (\off# -> k (I64#
-        off#
+#if defined(ARCH_32bit)
+                  off#
+#else
+          (intToInt64# off#)
+#endif
     ))))
 {-# INLINE peekByteOffset #-}
 
diff --git a/cborg/src/Codec/CBOR/Read.hs b/cborg/src/Codec/CBOR/Read.hs
index ac5df51..431e00e 100644
--- a/cborg/src/Codec/CBOR/Read.hs
+++ b/cborg/src/Codec/CBOR/Read.hs
@@ -1268,7 +1268,11 @@ go_slow da bs !offset = do
 
     SlowPeekByteOffset bs' k ->
       lift
+#if defined(ARCH_32bit)
         (k off#)
+#else
+        (k (int64ToInt# off#))
+#endif
         >>= \daz -> go_slow daz bs' offset'
       where
         !offset'@(I64# off#) = offset + intToInt64 (BS.length bs - BS.length bs')
@@ -1373,7 +1377,11 @@ go_slow_overlapped da sz bs_cur bs_next !offset =
       SlowPeekByteOffset bs_empty k ->
         assert (BS.null bs_empty) $ do
         lift
+#if defined(ARCH_32bit)
           (k off#)
+#else
+          (k (int64ToInt# off#))
+#endif
           >>= \daz -> go_slow daz bs' offset'
         where
           !(I64# off#) = offset'
