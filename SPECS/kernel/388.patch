 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm/boot/dts/st/stm32mp151.dtsi b/arch/arm/boot/dts/st/stm32mp151.dtsi
index aec7fa5ab5d8..fe79d5d40c11 100644
--- a/arch/arm/boot/dts/st/stm32mp151.dtsi
