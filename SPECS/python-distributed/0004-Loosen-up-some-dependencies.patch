From 5a9f0fea06252add40131f66a3882186a116565f Mon Sep 17 00:00:00 2001
From: Elliott Sales de Andrade <quantum.analyst@gmail.com>
Date: Tue, 18 Jun 2024 18:51:01 -0400
Subject: [PATCH 4/7] Loosen up some dependencies

Remove code coverage for testing, and allow newer versioneer.

Signed-off-by: Elliott Sales de Andrade <quantum.analyst@gmail.com>
---
 pyproject.toml | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index b7082f87..3283e179 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,5 +1,5 @@
 [build-system]
-requires = ["setuptools>=62.6", "versioneer[toml]==0.29"]
+requires = ["setuptools>=62.6", "versioneer[toml]>=0.29"]
 build-backend = "setuptools.build_meta"
 
 [project]
@@ -105,7 +105,6 @@ addopts = '''
 --ignore=.github
 --strict-markers
 --strict-config
---cov-config=pyproject.toml
 -p no:asyncio
 -p no:legacypath'''
 filterwarnings = [
-- 
2.50.0

