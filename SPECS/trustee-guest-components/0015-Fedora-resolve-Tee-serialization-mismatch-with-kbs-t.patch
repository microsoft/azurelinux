From 296bd6b5704884282e1ffed7ac27465c91f4098d Mon Sep 17 00:00:00 2001
From: Yan Fu <yafu@redhat.com>
Date: Mon, 3 Nov 2025 22:11:22 -0500
Subject: [PATCH 15/15] Fedora: resolve Tee serialization mismatch with
 kbs-types

Resolve the serialization mismatches and ensures correct communication
with the KBS server caused by commit 9a342778 in kbs-types crate.

Signed-off-by: Uri Lublin <uril@redhat.com>
Signed-off-by: Yan Fu <yafu@redhat.com>
---
 .../kbs_protocol/src/client/rcar_client.rs    | 33 +++++++++++++------
 1 file changed, 23 insertions(+), 10 deletions(-)

diff --git a/attestation-agent/kbs_protocol/src/client/rcar_client.rs b/attestation-agent/kbs_protocol/src/client/rcar_client.rs
index 0f2c5ef..c34a634 100644
--- a/attestation-agent/kbs_protocol/src/client/rcar_client.rs
+++ b/attestation-agent/kbs_protocol/src/client/rcar_client.rs
@@ -10,7 +10,7 @@ use async_trait::async_trait;
 use attester::TeeEvidence;
 use canon_json::CanonicalFormatter;
 use kbs_types::HashAlgorithm;
-use kbs_types::{Attestation, Challenge, ErrorInformation, Request, Response, RuntimeData, Tee};
+use kbs_types::{Attestation, Challenge, ErrorInformation, Response, RuntimeData, Tee};
 use log::{debug, warn};
 use resource_uri::ResourceUri;
 use serde::{Deserialize, Serialize};
@@ -97,17 +97,23 @@ fn serialize_json_canonically<T: Serialize>(value: T) -> anyhow::Result<Vec<u8>>
     Ok(buf)
 }
 
-async fn build_request(tee: Tee) -> Request {
+async fn build_request(tee: Tee) -> serde_json::Value {
     let extra_params = get_request_extra_params().await;
 
     // Note that the Request includes the list of supported hash algorithms.
     // The Challenge response will return which TEE-specific algorithm should
     // be used for future communications.
-    Request {
-        version: String::from(KBS_PROTOCOL_VERSION),
-        tee,
-        extra_params,
-    }
+    let tee_string_for_serialization = match tee {
+        Tee::AzSnpVtpm => "azsnpvtpm".to_string(),
+        Tee::AzTdxVtpm => "aztdxvtpm".to_string(),
+        _ => serde_json::to_string(&tee).unwrap().trim_matches('"').to_string(),
+    };
+
+    json!({
+        "version": KBS_PROTOCOL_VERSION,
+        "tee": tee_string_for_serialization,
+        "extra-params": extra_params,
+    })
 }
 
 impl KbsClient<Box<dyn EvidenceProvider>> {
@@ -549,9 +555,16 @@ mod test {
         for tee in tees {
             let request = build_request(tee).await;
 
-            assert_eq!(request.version, expected_version);
-            assert_eq!(request.tee, tee);
-            assert_eq!(request.extra_params, expected_extra_params);
+            let expected_tee_string = match tee {
+                Tee::AzSnpVtpm => "azsnpvtpm".to_string(),
+                Tee::AzTdxVtpm => "aztdxvtpm".to_string(),
+                _ => serde_json::to_string(&tee).unwrap().trim_matches('"').to_string(),
+            };
+
+            assert_eq!(request.get("version").unwrap().as_str().unwrap(), expected_version);
+            assert_eq!(request.get("tee").unwrap().as_str().unwrap(), expected_tee_string);
+            assert_eq!(request.get("extra-params").unwrap(), &expected_extra_params);
+
         }
     }
 
-- 
