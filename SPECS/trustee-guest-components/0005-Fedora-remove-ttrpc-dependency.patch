From 3c55448e32bb8330d6290354589cb9e176c07a1a Mon Sep 17 00:00:00 2001
From: Yan Fu <yafu@redhat.com>
Date: Tue, 21 Oct 2025 22:55:34 -0400
Subject: [PATCH 05/15] Fedora: remove ttrpc dependency

Not in Fedora and not required if not building aa_token

Also remove protobuf, as it's only used via ttrpc.

Also remove protos crate dependency, as it depends on ttrpc.

Signed-off-by: Uri Lublin <uril@redhat.com>
Signed-off-by: Yan Fu <yafu@redhat.com>
---
 Cargo.toml                                     | 3 ---
 attestation-agent/attestation-agent/Cargo.toml | 4 +---
 attestation-agent/kbs_protocol/Cargo.toml      | 5 +----
 3 files changed, 2 insertions(+), 10 deletions(-)

diff --git a/Cargo.toml b/Cargo.toml
index ebed6be..cb41d55 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -31,7 +31,6 @@ log = "0.4.28"
 nix = "0.30"
 openssl = "0.10"
 prost = "0.13"
-protobuf = "3.7.2"
 rand = "0.9.2"
 reqwest = { version = "0.12", default-features = false }
 resource_uri = { path = "attestation-agent/deps/resource_uri" }
@@ -50,8 +49,6 @@ tokio = "1.47"
 toml = "0.8.23"
 tonic = "0.12"
 tonic-build = "0.12"
-ttrpc = "0.9.0"
-ttrpc-codegen = "0.6.0"
 url = "2.5.4"
 uuid = "1"
 zeroize = "1.5.7"
diff --git a/attestation-agent/attestation-agent/Cargo.toml b/attestation-agent/attestation-agent/Cargo.toml
index 53d9543..a70aa15 100644
--- a/attestation-agent/attestation-agent/Cargo.toml
+++ b/attestation-agent/attestation-agent/Cargo.toml
@@ -33,7 +33,6 @@ hex.workspace = true
 kbs_protocol = { path = "../kbs_protocol", default-features = false, optional = true }
 kbs-types.workspace = true
 log.workspace = true
-protos = { path = "../../protos", default-features = false, optional = true }
 reqwest = { workspace = true, features = ["json"], optional = true }
 serde.workspace = true
 serde_json.workspace = true
@@ -108,5 +107,4 @@ openssl = ["kbs_protocol?/openssl"]
 
 # Binary RPC type
 bin = ["clap", "env_logger", "tokio/rt-multi-thread"]
-grpc = ["tokio/signal", "tonic", "protos/grpc"]
-ttrpc = ["dep:ttrpc", "tokio/signal", "protos/ttrpc"]
+grpc = ["tokio/signal", "tonic"]
diff --git a/attestation-agent/kbs_protocol/Cargo.toml b/attestation-agent/kbs_protocol/Cargo.toml
index e703f05..5fabfad 100644
--- a/attestation-agent/kbs_protocol/Cargo.toml
+++ b/attestation-agent/kbs_protocol/Cargo.toml
@@ -18,8 +18,6 @@ env_logger = { workspace = true, optional = true }
 jwt-simple.workspace = true
 kbs-types.workspace = true
 log.workspace = true
-protobuf = { workspace = true, optional = true }
-protos = { path = "../../protos", default-features = false, optional = true }
 reqwest = { workspace = true, features = ["cookies", "json"], optional = true }
 resource_uri.path = "../deps/resource_uri"
 serde.workspace = true
@@ -27,7 +25,6 @@ serde_json.workspace = true
 sha2.workspace = true
 thiserror.workspace = true
 tokio.workspace = true
-ttrpc = { workspace = true, optional = true }
 url.workspace = true
 zeroize.workspace = true
 
@@ -49,7 +46,7 @@ default = ["background_check", "passport", "openssl", "all-attesters", "bin"]
 
 passport = []
 # Allow to connect Attestation-Agent with TTRPC to get evidence, token, etc.
-aa_ttrpc = ["passport", "ttrpc/async", "protos/ttrpc"]
+aa_ttrpc = []
 
 background_check = ["tokio/time", "canon-json"]
 all-attesters = ["attester/all-attesters"]
-- 
2.51.1

