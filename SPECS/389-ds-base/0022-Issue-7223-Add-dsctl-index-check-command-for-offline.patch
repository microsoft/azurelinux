+    ancestorid_entry = [
+        "dn: cn=ancestorid,cn=index,cn=userRoot,cn=ldbm database,cn=plugins,cn=config\n",
+        "objectClass: top\n",
+        "objectClass: nsIndex\n",
+        "cn: ancestorid\n",
+        "nsSystemIndex: true\n",
+        "nsIndexType: eq\n",
+    ]
+    dse_ldif.add_entry(ancestorid_entry)
