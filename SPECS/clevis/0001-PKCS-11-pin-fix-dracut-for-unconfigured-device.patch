         while((t = strtok(t, ","))) {
             if (is_device) {
                 fprintf(logfile, "Adding device:%s\n", t);
@@ -185,7 +184,7 @@ static void dump_wide_version(void) {
 
 static void int_handler(int s) {
     if(logfile) {
-        fprintf(logfile, "Closing, signal:[%d]\n", s);
