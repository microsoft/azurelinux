From 065d3007bf244b244ff0f0c8deaf177bd481932b Mon Sep 17 00:00:00 2001
From: Dan Callaghan <djc@djc.id.au>
Date: Sun, 8 Aug 2021 18:49:03 +1000
Subject: [PATCH 1/2] build shared library


diff --git a/.gitignore b/.gitignore
index 7ab7825..97a63cb 100644
--- a/.gitignore
+++ b/.gitignore
@@ -1,3 +1,4 @@
+liblinenoise.so*
 linenoise_example
 *.dSYM
 history.txt
diff --git a/Makefile b/Makefile
index a285410..fa08b2b 100644
--- a/Makefile
+++ b/Makefile
@@ -1,7 +1,33 @@
+MAJOR_VERSION = 0
+EXTRA_VERSION = .0.0
+SONAME = liblinenoise.so.$(MAJOR_VERSION)
+LIB = $(SONAME)$(EXTRA_VERSION)
+
+export CFLAGS ?= -Os -g
+CFLAGS += -Wall -fpic
+LIBDIR ?= /usr/lib
+INCLUDEDIR ?= /usr/include
+
+.PHONY: all
+all: $(LIB) linenoise_example
+
+$(LIB): linenoise.o
+	$(CC) $(CFLAGS) -shared -Wl,-soname,$(SONAME) $(LDFLAGS) -o $@ $^
+
 linenoise_example: linenoise.h linenoise.c
 
 linenoise_example: linenoise.c example.c
 	$(CC) -Wall -W -Os -g -o linenoise_example linenoise.c example.c
 
+.PHONY: clean
 clean:
-	rm -f linenoise_example
+	rm -f $(LIB) linenoise_example *.o
+
+.PHONY: install
+install: $(LIB)
+	install -m 0755 -d $(DESTDIR)$(INCLUDEDIR)
+	install -m 0644 linenoise.h $(DESTDIR)$(INCLUDEDIR)
+	install -m 0755 -d $(DESTDIR)$(LIBDIR)
+	install -m 0755 $(LIB) $(DESTDIR)$(LIBDIR)
+	ldconfig -n $(DESTDIR)$(LIBDIR)
+	ln -s $(LIB) $(DESTDIR)$(LIBDIR)/liblinenoise.so
-- 
