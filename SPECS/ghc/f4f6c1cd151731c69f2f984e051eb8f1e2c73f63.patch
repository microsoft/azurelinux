+    , size
+    , member
+    , notMember
+    , lookupLT
+    , lookupGT
+    , lookupLE
+    , lookupGE
+    , isSubsetOf
+    , isProperSubsetOf
+    , disjoint
+
+    -- * Construction
+    , empty
+    , singleton
+    , insert
+    , delete
+    , alterF
+
+    -- * Combine
+    , union
+    , unions
+    , difference
+    , intersection
