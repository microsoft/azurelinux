From: Durga Jagadeesh Palli <v-dpalli@microsoft.com>
Date: Tue, 17 Mar 2026 00:55:30 +0000
Subject: [PATCH] fix: use std::move to resolve GCC uninitialized warning

Upstream Patch reference:https://github.com/apache/arrow/issues/44788

---
 cpp/src/arrow/util/iterator.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/cpp/src/arrow/util/iterator.h b/cpp/src/arrow/util/iterator.h
index 5e716d0..19ed36a 100644
--- a/cpp/src/arrow/util/iterator.h
+++ b/cpp/src/arrow/util/iterator.h
@@ -285,7 +285,7 @@ class TransformIterator {
         finished_ = true;
         return next_res.status();
       }
-      auto next = *next_res;
+      auto next = std::move(*next_res);
       if (next.ReadyForNext()) {
         if (IsIterationEnd(*last_value_)) {
           finished_ = true;
