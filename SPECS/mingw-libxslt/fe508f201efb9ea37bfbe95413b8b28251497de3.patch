diff -rupN --no-dereference libxslt-v1.1.43/libexslt/functions.c libxslt-v1.1.43-new/libexslt/functions.c
--- libxslt-v1.1.43/libexslt/functions.c	2025-03-12 18:38:02.000000000 +0100
