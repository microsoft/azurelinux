+++ b/bundler/spec/support/rubygems_ext.rb
@@ -50,6 +50,22 @@ def test_setup
       Gem::DefaultUserInteraction.ui = Gem::SilentUI.new
     end
 
+    def install_parallel_test_deps
+      Gem.clear_paths
+
+      require "parallel"
+      require "fileutils"
+
+      install_test_deps
+
+      (2..Parallel.processor_count).each do |n|
