From 6932029f3ab5193acd26e8bac91aff5af464067e Mon Sep 17 00:00:00 2001
From: "Benjamin A. Beasley" <code@musicinmybrain.net>
Date: Tue, 23 Sep 2025 13:33:43 +0100
Subject: [PATCH 1/3] Downstream patch: always find the system-wide ruff
 executable
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The following issue is for uv, but the situation is exactly the same.

“Should uv.find_uv_bin() be able to find /usr/bin/uv?”
https://github.com/astral-sh/uv/issues/4451
---
 python/ruff/__main__.py | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/python/ruff/__main__.py b/python/ruff/__main__.py
index 8569844c4e..38e045b090 100644
--- a/python/ruff/__main__.py
+++ b/python/ruff/__main__.py
@@ -10,6 +10,16 @@ def find_ruff_bin() -> str:
 
     ruff_exe = "ruff" + sysconfig.get_config_var("EXE")
 
+    # Downstream patch: always find the system-wide ruff executable
+    #
+    # The following issue is for uv, but the situation is exactly the same.
+    #
+    # “Should uv.find_uv_bin() be able to find /usr/bin/uv?”
+    # https://github.com/astral-sh/uv/issues/4451
+    bindir_path = os.path.join(sysconfig.get_config_var("BINDIR"), ruff_exe)
+    if os.path.isfile(bindir_path):
+        return bindir_path
+
     scripts_path = os.path.join(sysconfig.get_path("scripts"), ruff_exe)
     if os.path.isfile(scripts_path):
         return scripts_path
-- 
