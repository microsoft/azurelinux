-	asprintf(&tmp,"%s/%s",win32_def_path,x?(x+1):cs1);
-//	printf("### Open: %s -> %s\n",cs1,tmp);
-	result=open(tmp, O_RDONLY);
-	free(tmp);
+        if (asprintf (&tmp,"%s/%s",win32_def_path,x?(x+1):cs1) >= 0) {
+            // printf("### Open: %s -> %s\n",cs1,tmp);
+            result = open (tmp, O_RDONLY);
