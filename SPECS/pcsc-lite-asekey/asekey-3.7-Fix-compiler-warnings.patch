+                if (retVal < 0 || *RxLength < (DWORD)actual) {
                     if (RxLength)
-	    	            *RxLength = 0;
-		            return IFD_COMMUNICATION_ERROR;
-		        }
-		        *RxLength = actual;
+                        *RxLength = 0;
+                    return IFD_COMMUNICATION_ERROR;
+                }
+                *RxLength = actual;
                 if (*RxLength)
-		            memcpy(RxBuffer, response, *RxLength);
+                    memcpy(RxBuffer, response, *RxLength);
             }
             break;
         default:
@@ -723,11 +723,11 @@ RESPONSECODE IFDHControl ( DWORD Lun,
