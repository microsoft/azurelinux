+        return IFD_COMMUNICATION_ERROR;
     }
 
     switch (SendPci.Protocol) {
@@ -657,14 +657,14 @@ RESPONSECODE IFDHTransmitToICC ( DWORD Lun, SCARD_IO_HEADER SendPci,
