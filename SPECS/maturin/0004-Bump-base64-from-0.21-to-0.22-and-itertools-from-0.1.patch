 glob = "0.3.0"
 cargo-config2 = "0.1.24"
 cargo_metadata = "0.19.0"
@@ -77,7 +77,7 @@ pyproject-toml = { version = "0.13.5", features = ["pep639-glob"] }
 python-pkginfo = "0.6.5"
 textwrap = "0.16.1"
 ignore = "0.4.20"
-itertools = "0.12.1"
