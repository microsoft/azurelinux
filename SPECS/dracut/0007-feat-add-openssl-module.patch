@@ -0,0 +1,29 @@
+#!/bin/sh
+
+eok() {
+
+    {
+        [ "$1" -eq 0 ] && echo OK || echo FAIL
+
+        echo
+
+    } 2> /dev/null
+}
+
+echo
+
+set -x
+
+openssl list -providers
+
+eok "$?"
