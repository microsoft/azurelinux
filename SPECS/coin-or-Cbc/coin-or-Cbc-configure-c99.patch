Avoid implicit function declarations in the configure script.  This
is partly a package-specific change, specifically the addition
of “char $fnm (void);” in Cbc/configure.

The problematic configure snippet is no longer present upstream.
Upstream does not include the full sources for the autoconf script, so
it is hard to tell.  In the BuildTools repository, the problematic
AC_COIN_CHECK_USER_LIBRARY macro was removed in this commit (search
for “$fnm”):

commit f0363fe4ef8b11940138a39fb90ec53717e0b5de
Author: Stefan Vigerske <svigerske@gams.com>
Date:   Wed Dec 4 20:53:33 2013 +0000

    give coin.m4 a fresh start, see also #95

diff --git a/Cbc/configure b/Cbc/configure
index 7b3f984b81c2620b..9d3cb8472703a857 100755
--- a/Cbc/configure
+++ b/Cbc/configure
@@ -2710,7 +2710,7 @@ if { (eval echo "$as_me:$LINENO: \"$ac_compile\"") >&5
   echo "$as_me:$LINENO: \$? = $ac_status" >&5
   (exit $ac_status); }; }; then
   for ac_declaration in \
-   '' \
+   '#include <stdlib.h>' \
    'extern "C" void std::exit (int) throw (); using std::exit;' \
    'extern "C" void std::exit (int); using std::exit;' \
    'extern "C" void exit (int) throw ();' \
@@ -6410,8 +6410,8 @@ main ()
   for (i = 0; i < 256; i++)
     if (XOR (islower (i), ISLOWER (i))
 	|| toupper (i) != TOUPPER (i))
-      exit(2);
-  exit (0);
+      return 2;
+  return 0;
 }
 _ACEOF
 rm -f conftest$ac_exeext
@@ -30776,6 +30776,8 @@ cat confdefs.h >>conftest.$ac_ext
 cat >>conftest.$ac_ext <<_ACEOF
 /* end confdefs.h.  */
 
+char $fnm(void);
+
 int
 main ()
 {
