 drivers/hv/Makefile                |   1 +
 drivers/hv/hv_vsm.h                |   1 +
 drivers/hv/hv_vsm_common.c         |  25 ++
 drivers/hv/mshv_vsm_vtl1.c         | 374 +++++++++++++++++++++++++++++
 5 files changed, 403 insertions(+)
 create mode 100644 drivers/hv/mshv_vsm_vtl1.c

