--- a/drivers/hv/hv_vsm.h
+++ b/drivers/hv/hv_vsm.h
@@ -34,6 +34,7 @@ union hv_register_vsm_code_page_offsets {
 } __packed;
 
 int hv_vsm_get_register(u32 reg_name, u64 *result);
