      <packagereq arch="aarch64" type="mandatory">grub2-efi-aa64</packagereq>
      <packagereq arch="aarch64" type="mandatory">grub2-efi-aa64-cdboot</packagereq>
      <packagereq arch="x86_64" type="mandatory">grub2-efi-ia32</packagereq>
