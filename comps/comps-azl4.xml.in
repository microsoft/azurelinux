      <packagereq type="mandatory">xfce4-session</packagereq>
      <packagereq type="mandatory">xfce4-settings</packagereq>
      <packagereq type="mandatory">xfconf</packagereq>
      <packagereq type="mandatory">xfdesktop</packagereq>
      <packagereq type="mandatory">xfwm4</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xfce-extra-plugins</id>
    <_name>Extra plugins for the Xfce panel</_name>
    <_description>Extend the functionality of the Xfce panel</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq>xfce4-battery-plugin</packagereq>
      <packagereq>xfce4-cpugraph-plugin</packagereq>
      <packagereq>xfce4-diskperf-plugin</packagereq>
      <packagereq>xfce4-eyes-plugin</packagereq>
      <packagereq>xfce4-fsguard-plugin</packagereq>
      <packagereq>xfce4-genmon-plugin</packagereq>
      <packagereq>xfce4-mailwatch-plugin</packagereq>
      <packagereq>xfce4-mount-plugin</packagereq>
      <packagereq>xfce4-netload-plugin</packagereq>
      <packagereq>xfce4-panel-profiles</packagereq>
      <packagereq arch="aarch64,ppc64le,x86_64">xfce4-sensors-plugin</packagereq>
      <packagereq>xfce4-systemload-plugin</packagereq>
      <packagereq>xfce4-time-out-plugin</packagereq>
      <packagereq>xfce4-verve-plugin</packagereq>
      <packagereq>xfce4-weather-plugin</packagereq>
      <packagereq>xfce4-whiskermenu-plugin</packagereq>
      <packagereq>xfce4-xkb-plugin</packagereq>
      <packagereq>xfdashboard</packagereq>
      <packagereq>xfdashboard-themes</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xfce-media</id>
    <_name>Multimedia support for Xfce</_name>
    <_description>Multimedia support for Xfce</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq>asunder</packagereq>
      <packagereq>parole</packagereq>
      <packagereq>pavucontrol</packagereq>
      <packagereq>pragha</packagereq>
      <packagereq>xfburn</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xfce-office</id>
    <_name>Xfce Office</_name>
    <_description>Office suite for Xfce</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq>libreoffice-calc</packagereq>
      <packagereq>libreoffice-writer</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xfce-software-development</id>
    <_name>Xfce Software Development</_name>
    <_description>Install these packages in order to develop GTK+ and Xfce graphical applications.</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq type="mandatory">libxfce4ui-devel</packagereq>
      <packagereq type="mandatory">libxfce4util-devel</packagereq>
      <packagereq type="default">exo-devel</packagereq>
      <packagereq type="default">garcon-devel</packagereq>
      <packagereq type="default">Thunar-devel</packagereq>
      <packagereq type="default">tumbler-devel</packagereq>
      <packagereq type="default">xfce4-dev-tools</packagereq>
      <packagereq type="default">xfce4-panel-devel</packagereq>
      <packagereq type="default">xfconf-devel</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xmonad</id>
    <_name>XMonad</_name>
    <_description>A tiling window manager</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq>xmobar</packagereq>
      <packagereq>xmonad</packagereq>
    </packagelist>
  </group>
  <group>
    <id>xmonad-mate</id>
    <_name>XMonad for MATE</_name>
    <_description>XMonad window manager with MATE</_description>
    <default>false</default>
    <uservisible>false</uservisible>
    <packagelist>
      <packagereq>mate-control-center</packagereq>
      <packagereq>mate-panel</packagereq>
      <packagereq>mate-screensaver</packagereq>
      <packagereq>xmonad-mate</packagereq>
    </packagelist>
  </group>
  <environment>
    <!-- Intended to allow interactive installation of components that will eventually be
         used in a cloud image. -->
    <id>cloud-server-environment</id>
    <_name>Fedora Cloud Server</_name>
    <_description>A server install with components needed to run in a cloud environment.</_description>
    <display_order>3</display_order>
    <grouplist>
      <groupid>cloud-bootloader-tools</groupid>
      <groupid>cloud-server</groupid>
      <groupid>container-management</groupid>
      <groupid>core</groupid>
    </grouplist>
    <optionlist>
      <groupid>standard</groupid>
      <groupid>headless-management</groupid>
      <groupid>dogtag</groupid>
      <groupid>directory-server</groupid>
      <groupid>dns-server</groupid>
      <groupid>freeipa-server</groupid>
      <groupid>ftp-server</groupid>
      <groupid>guest-agents</groupid>
      <groupid>ha</groupid>
      <groupid>load-balancer</groupid>
      <groupid>mail-server</groupid>
      <groupid>mysql</groupid>
      <groupid>network-server</groupid>
      <groupid>smb-server</groupid>
      <groupid>sql-server</groupid>
      <groupid>web-server</groupid>
      <groupid>domain-client</groupid>
    </optionlist>
  </environment>
  <langpacks>
    <match install="man-pages-%s" name="man-pages"/>
  </langpacks>
</comps>
