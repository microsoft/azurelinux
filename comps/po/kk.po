#: ../comps-f32.xml.in.h:1 ../comps-f33.xml.in.h:1 ../comps-f34.xml.in.h:1
msgid "3D Printing"
msgstr "3D баспаға шығару"

#: ../comps-f32.xml.in.h:2 ../comps-f33.xml.in.h:2 ../comps-f34.xml.in.h:2
msgid "3D printing software"
msgstr "3D баспаға шығару БҚ"

#: ../comps-f32.xml.in.h:3 ../comps-f33.xml.in.h:3 ../comps-f34.xml.in.h:3
msgid "Administration Tools"
msgstr "Әкімшілік саймандары"

#: ../comps-f32.xml.in.h:4 ../comps-f33.xml.in.h:4 ../comps-f34.xml.in.h:4
msgid ""
"This group is a collection of graphical administration tools for the system, "
"such as for managing user accounts and configuring system hardware."
msgstr ""
"Бұл топ пайдаланушы тіркелгілерін басқару және жүйелік жабдықты "
"конфигурациялау сияқты жүйеге арналған графикалық басқару құралдарының "
"жиынтығы болып табылады."

#: ../comps-f32.xml.in.h:5 ../comps-f33.xml.in.h:5 ../comps-f34.xml.in.h:5
msgid "Anaconda tools"
msgstr "Anaconda саймандары"

#: ../comps-f32.xml.in.h:6 ../comps-f33.xml.in.h:6 ../comps-f34.xml.in.h:6
msgid "ARM Tools"
msgstr "ARM құралдары"

#: ../comps-f32.xml.in.h:7 ../comps-f33.xml.in.h:7 ../comps-f34.xml.in.h:7
msgid "Tools for working with arm systems"
msgstr "ARM жүйелерімен жұмыс істеуге арналған құралдар"

#: ../comps-f32.xml.in.h:8 ../comps-f33.xml.in.h:8 ../comps-f34.xml.in.h:8
msgid "x86 Baremetal Tools"
msgstr "x86 Baremetal құралдары"

#: ../comps-f32.xml.in.h:9 ../comps-f33.xml.in.h:9 ../comps-f34.xml.in.h:9
msgid "Tools for working with baremetal x86 systems"
msgstr "Baremetal x86 жүйелерімен жұмыс істеуге арналған саймандар"

#: ../comps-f32.xml.in.h:10 ../comps-f33.xml.in.h:10 ../comps-f34.xml.in.h:10
msgid "Audio Production"
msgstr "Аудио өндірісі"

#: ../comps-f32.xml.in.h:11 ../comps-f33.xml.in.h:11 ../comps-f34.xml.in.h:11
msgid "Various tools for audio synthesis and music production."
msgstr "Аудио синтезі мен музыканы шығаруға арналған әртүрлі құралдар."

#: ../comps-f32.xml.in.h:12 ../comps-f33.xml.in.h:12 ../comps-f34.xml.in.h:12
msgid "Authoring and Publishing"
msgstr "Жариялауды дайындау"

#: ../comps-f32.xml.in.h:13 ../comps-f33.xml.in.h:13 ../comps-f34.xml.in.h:13
msgid ""
"These tools allow you to create documents in the DocBook format and convert "
"them into HTML, PDF, Postscript, and text."
msgstr ""
"Бұл құралдар DocBook пішімінде құжаттарды жасауға және оларды HTML, PDF, "
"Postscript және мәтінге түрлендіруге мүмкіндік береді."

#: ../comps-f32.xml.in.h:14 ../comps-f33.xml.in.h:14 ../comps-f34.xml.in.h:14
msgid "base-x"
msgstr "base-x"

#: ../comps-f32.xml.in.h:15 ../comps-f33.xml.in.h:15 ../comps-f34.xml.in.h:15
msgid "Local X.org display server"
msgstr "Жергілікті X.org дисплей сервері"

#: ../comps-f32.xml.in.h:16 ../comps-f33.xml.in.h:16 ../comps-f34.xml.in.h:16
msgid "Basic Desktop"
msgstr "Негізгі жұмыс үстелі"

#: ../comps-f32.xml.in.h:17 ../comps-f33.xml.in.h:17 ../comps-f34.xml.in.h:17
msgid "Basic X Window System with a choice of window manager."
msgstr "Терезе менеджерін таңдауы бар негізгі X Window жүйесі."

#: ../comps-f32.xml.in.h:18
msgid "Books and Guides"
msgstr "Кітаптар мен нұсқаулықтар"

#: ../comps-f32.xml.in.h:19
msgid "Books and Guides for Fedora users and developers"
msgstr ""
"Fedora пайдаланушылары мен әзірлеушілеріне арналған кітаптар мен нұсқаулықтар"

#: ../comps-f32.xml.in.h:20 ../comps-f33.xml.in.h:18 ../comps-f34.xml.in.h:18
#: ../comps-epel7.xml.in.h:25
msgid "Buildsystem building group"
msgstr "Құрастыру жүйесін құрастыру тобы"

#: ../comps-f32.xml.in.h:21 ../comps-f33.xml.in.h:19 ../comps-f34.xml.in.h:19
msgid "C Development Tools and Libraries"
msgstr "C тілінде әзірлеу құралдары мен кітапханалар"

#: ../comps-f32.xml.in.h:22 ../comps-f33.xml.in.h:20 ../comps-f34.xml.in.h:20
msgid ""
"These tools include core development tools such as automake, gcc and "
"debuggers."
msgstr ""
"Бұл құралдарға automake, gcc және жөндегіш сияқты негізгі әзірлеу құралдары "
"кіреді."

#: ../comps-f32.xml.in.h:23 ../comps-f33.xml.in.h:21 ../comps-f34.xml.in.h:21
#: ../comps-epel7.xml.in.h:34
msgid "Cinnamon"
msgstr "Cinnamon"

#: ../comps-f32.xml.in.h:24 ../comps-f33.xml.in.h:22 ../comps-f34.xml.in.h:22
#: ../comps-epel7.xml.in.h:35
msgid ""
"Cinnamon provides a desktop with a traditional layout, advanced features, "
"easy to use, powerful and flexible."
msgstr ""
"Cinnamon жұмыс үстелін дәстүрлі орналасуымен, кеңейтілген мүмкіндіктерімен "
"ұсынады, ол пайдалануға оңай, қуатты және икемділігін қамтамасыз етеді."

#: ../comps-f32.xml.in.h:25 ../comps-f33.xml.in.h:23 ../comps-f34.xml.in.h:23
msgid "Cloud Infrastructure"
msgstr "Бұлттық инфрақұрылым"

#: ../comps-f32.xml.in.h:26 ../comps-f33.xml.in.h:24 ../comps-f34.xml.in.h:24
msgid "Infrastructure packages for cloud computing."
msgstr "Бұлттық есептеулерге арналған инфрақұрылым дестелері."

#: ../comps-f32.xml.in.h:27 ../comps-f33.xml.in.h:25 ../comps-f34.xml.in.h:25
msgid "Cloud Management Tools"
msgstr "Бұлтты басқару құралдары"

#: ../comps-f32.xml.in.h:28 ../comps-f33.xml.in.h:26 ../comps-f34.xml.in.h:26
msgid ""
"Software to manage servers and system images that run in \"cloud\" "
"environments"
msgstr ""
"\"Бұлттық\" орталарда жұмыс істейтін серверлер мен жүйелік бейнелерді "
"басқаруға арналған бағдарламалық қамтама"

#: ../comps-f32.xml.in.h:29 ../comps-f33.xml.in.h:27 ../comps-f34.xml.in.h:27
msgid "Cloud Server Tools"
msgstr "Бұлттық сервер саймандары"

#: ../comps-f32.xml.in.h:30 ../comps-f33.xml.in.h:28 ../comps-f34.xml.in.h:28
msgid ""
"Software for servers and system images that run in \"cloud\" environments"
msgstr ""
"\"Бұлттық\" орталарда орындалатын серверлер мен жүйелік бейнелерге арналған "
"бағдарламалық қамтама"

#: ../comps-f32.xml.in.h:31 ../comps-f33.xml.in.h:29 ../comps-f34.xml.in.h:29
msgid "Compiz"
msgstr "Compiz"

#: ../comps-f32.xml.in.h:32 ../comps-f33.xml.in.h:30 ../comps-f34.xml.in.h:30
msgid "This package group adds Compiz and Emerald"
msgstr "Бұл дестелер тобы Compiz және Emerald қосады"

#: ../comps-f32.xml.in.h:33 ../comps-f33.xml.in.h:31 ../comps-f34.xml.in.h:31
msgid "Container Management"
msgstr "Контейнерлерді басқару"

#: ../comps-f32.xml.in.h:34 ../comps-f33.xml.in.h:32 ../comps-f34.xml.in.h:32
msgid "Tools for managing Linux containers"
msgstr "Linux контейнерлерін басқаруға арналған саймандар"

#: ../comps-f32.xml.in.h:35 ../comps-f33.xml.in.h:33 ../comps-f34.xml.in.h:33
#: ../comps-epel7.xml.in.h:41
msgid "Core"
msgstr "Негізгі"

#: ../comps-f32.xml.in.h:36 ../comps-f33.xml.in.h:34 ../comps-f34.xml.in.h:34
msgid "Smallest possible installation"
msgstr "Мүмкін болатын ең кіші орнатылым"

#: ../comps-f32.xml.in.h:37 ../comps-f33.xml.in.h:35 ../comps-f34.xml.in.h:35
msgid "Critical Path (Applications)"
msgstr "Критикалық жол (Қолданбалар)"

#: ../comps-f32.xml.in.h:38 ../comps-f33.xml.in.h:36 ../comps-f34.xml.in.h:36
msgid "A set of applications that are considered critical path"
msgstr "Критикалық жол деп есептелетін қолданбалар жиынтығы"

#: ../comps-f32.xml.in.h:39 ../comps-f33.xml.in.h:37 ../comps-f34.xml.in.h:37
msgid "Critical Path (Base)"
msgstr "Критикалық жол (Базалық)"

#: ../comps-f32.xml.in.h:40 ../comps-f33.xml.in.h:38 ../comps-f34.xml.in.h:38
msgid ""
"A set of packages that provide the shared platform for Critical Path "
"functionality on all Fedora spins"
msgstr ""
"Барлық Fedora нұсқаларында Критикалық жол функционалдылығы үшін ортақ "
"платформаны қамтамасыз ететін дестелер жиынтығы"

#: ../comps-f32.xml.in.h:41 ../comps-f33.xml.in.h:39 ../comps-f34.xml.in.h:39
msgid "Critical Path (Deepin desktop)"
msgstr "Критикалық жол (Deepin жұмыс үстелі)"

#: ../comps-f32.xml.in.h:42 ../comps-f33.xml.in.h:40 ../comps-f34.xml.in.h:40
msgid ""
"A set of packages that provide the Critical Path functionality for the "
"Deepin desktop"
msgstr ""
"Deepin жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:43 ../comps-f33.xml.in.h:41 ../comps-f34.xml.in.h:41
msgid "Critical Path (GNOME)"
msgstr "Критикалық жол (GNOME)"

#: ../comps-f32.xml.in.h:44 ../comps-f33.xml.in.h:42 ../comps-f34.xml.in.h:42
msgid ""
"A set of packages that provide the Critical Path functionality for the GNOME "
"desktop"
msgstr ""
"GNOME жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:45 ../comps-f33.xml.in.h:43 ../comps-f34.xml.in.h:43
#: ../comps-epel8.xml.in.h:3
msgid "Critical Path (KDE)"
msgstr "Критикалық жол (KDE)"

#: ../comps-f32.xml.in.h:46 ../comps-f33.xml.in.h:44 ../comps-f34.xml.in.h:44
#: ../comps-epel8.xml.in.h:4
msgid ""
"A set of packages that provide the Critical Path functionality for the KDE "
"desktop"
msgstr ""
"KDE жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:47 ../comps-f33.xml.in.h:45 ../comps-f34.xml.in.h:45
msgid "Critical Path (LXDE)"
msgstr "Критикалық жол (LXDE)"

#: ../comps-f32.xml.in.h:48 ../comps-f33.xml.in.h:46 ../comps-f34.xml.in.h:46
msgid ""
"A set of packages that provide the Critical Path functionality for the LXDE "
"desktop"
msgstr ""
"LXDE жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:49 ../comps-f33.xml.in.h:47 ../comps-f34.xml.in.h:47
msgid "Critical Path (LXQt)"
msgstr "Критикалық жол (LXQt)"

#: ../comps-f32.xml.in.h:50 ../comps-f33.xml.in.h:48 ../comps-f34.xml.in.h:48
msgid ""
"A set of packages that provide the Critical Path functionality for the LXQt "
"desktop"
msgstr ""
"LXQt жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:51 ../comps-f33.xml.in.h:49 ../comps-f34.xml.in.h:49
msgid "Critical Path (Xfce)"
msgstr "Критикалық жол (Xfce)"

#: ../comps-f32.xml.in.h:52 ../comps-f33.xml.in.h:50 ../comps-f34.xml.in.h:50
msgid ""
"A set of packages that provide the Critical Path functionality for the Xfce "
"desktop"
msgstr ""
"Xfce жұмыс үстелі үшін Критикалық жол функционалдылығын қамтамасыз ететін "
"дестелер жиынтығы"

#: ../comps-f32.xml.in.h:53 ../comps-f33.xml.in.h:51 ../comps-f34.xml.in.h:51
msgid "D Development Tools and Libraries"
msgstr "D әзірлеу саймандары мен кітапханалары"

#: ../comps-f32.xml.in.h:54 ../comps-f33.xml.in.h:52 ../comps-f34.xml.in.h:52
msgid ""
"These include development tools and libraries such as ldc, and geany-tag."
msgstr ""
"Бұған ldc және geany-tag сияқты әзірлеу саймандары мен кітапханалары кіреді."

#: ../comps-f32.xml.in.h:55 ../comps-f33.xml.in.h:53 ../comps-f34.xml.in.h:53
msgid "Deepin Desktop Environment"
msgstr "Deepin жұмыс үстелі ортасы"

#: ../comps-f32.xml.in.h:56 ../comps-f33.xml.in.h:54 ../comps-f34.xml.in.h:54
msgid ""
"Deepin Desktop is a desktop environment aims at being elegant and easy to "
"use."
msgstr ""
"Deepin Desktop — талғампаз және пайдалануға оңай болуды мақсат ететін жұмыс "
"үстелі ортасы."

#: ../comps-f32.xml.in.h:57 ../comps-f33.xml.in.h:55 ../comps-f34.xml.in.h:55
msgid "Deepin Desktop Applications"
msgstr "Deepin жұмыс үстелі қолданбалары"

#: ../comps-f32.xml.in.h:58 ../comps-f33.xml.in.h:56 ../comps-f34.xml.in.h:56
msgid "Media packages for Deepin Desktop"
msgstr "Deepin жұмыс үстеліне арналған медиа дестелер"

#: ../comps-f32.xml.in.h:59 ../comps-f33.xml.in.h:57 ../comps-f34.xml.in.h:57
msgid "Deepin Desktop Office"
msgstr "Deepin жұмыс үстелі офисі"

#: ../comps-f32.xml.in.h:60 ../comps-f33.xml.in.h:58 ../comps-f34.xml.in.h:58
msgid "Office suite for Deepin Desktop"
msgstr "Deepin жұмыс үстеліне арналған офис пакеті"

#: ../comps-f32.xml.in.h:61 ../comps-f33.xml.in.h:59 ../comps-f34.xml.in.h:59
msgid "Design Suite"
msgstr "Дизайн пакеті"

#: ../comps-f32.xml.in.h:62 ../comps-f33.xml.in.h:60 ../comps-f34.xml.in.h:60
msgid ""
"These packages are targeted towards professional designers, and are related "
"to graphics, web and animation."
msgstr ""
"Бұл дестелер кәсіби дизайнерлерге арналған және графикаға, вебке және "
"анимацияға қатысты."

#: ../comps-f32.xml.in.h:63 ../comps-f33.xml.in.h:61 ../comps-f34.xml.in.h:61
msgid "Development Libraries"
msgstr "Әзірлеу кітапханалары"

#: ../comps-f32.xml.in.h:64 ../comps-f33.xml.in.h:62 ../comps-f34.xml.in.h:62
msgid ""
"The packages in this group are core libraries needed to develop applications."
msgstr ""
"Бұл топтағы дестелер қолданбаларды әзірлеу үшін қажетті негізгі кітапханалар "
"болып табылады."

#: ../comps-f32.xml.in.h:65 ../comps-f33.xml.in.h:63 ../comps-f34.xml.in.h:63
msgid "Development Tools"
msgstr "Әзірлеу саймандары"

#: ../comps-f32.xml.in.h:66 ../comps-f33.xml.in.h:64 ../comps-f34.xml.in.h:64
msgid "These tools include general development tools such as git and CVS."
msgstr "Бұл саймандарға git және CVS сияқты жалпы әзірлеу саймандары кіреді."

#: ../comps-f32.xml.in.h:67 ../comps-f33.xml.in.h:65 ../comps-f34.xml.in.h:65
#: ../comps-epel7.xml.in.h:56
msgid "Dial-up Networking Support"
msgstr "Диалап (Dial-up) желісін қолдау"

#: ../comps-f32.xml.in.h:68 ../comps-f33.xml.in.h:66 ../comps-f34.xml.in.h:66
#: ../comps-epel7.xml.in.h:60
msgid "Directory Server"
msgstr "Бумалар сервері"

#: ../comps-f32.xml.in.h:69 ../comps-f33.xml.in.h:67 ../comps-f34.xml.in.h:67
#: ../comps-epel7.xml.in.h:61
msgid "Machine and user identity servers."
msgstr "Машиналық және пайдаланушылық сәйкестендіру серверлері."

#: ../comps-f32.xml.in.h:70 ../comps-f33.xml.in.h:68 ../comps-f34.xml.in.h:68
msgid "DNS Name Server"
msgstr "DNS атаулар сервері"

#: ../comps-f32.xml.in.h:71 ../comps-f33.xml.in.h:69 ../comps-f34.xml.in.h:69
msgid ""
"This package group allows you to run a DNS name server (BIND) on the system."
msgstr ""
"Бұл дестелер тобы жүйеде DNS атаулар серверін (BIND) іске қосуға мүмкіндік "
"береді."

#: ../comps-f32.xml.in.h:72 ../comps-f33.xml.in.h:70 ../comps-f34.xml.in.h:70
msgid "Dogtag Certificate System"
msgstr "Dogtag сертификаттар жүйесі"

#: ../comps-f32.xml.in.h:73 ../comps-f33.xml.in.h:71 ../comps-f34.xml.in.h:71
msgid "Enterprise-class open source Certificate Authority"
msgstr "Кәсіпорын деңгейіндегі ашық бастапқы кодты сертификаттау орталығы"

#: ../comps-f32.xml.in.h:74 ../comps-f33.xml.in.h:72 ../comps-f34.xml.in.h:72
msgid "Domain Membership"
msgstr "Доменге мүшелік"

#: ../comps-f32.xml.in.h:75 ../comps-f33.xml.in.h:73 ../comps-f34.xml.in.h:73
msgid "Support for joining a FreeIPA or Active Directory Domain"
msgstr "FreeIPA немесе Active Directory доменіне қосылуды қолдау"

#: ../comps-f32.xml.in.h:76 ../comps-f33.xml.in.h:74 ../comps-f34.xml.in.h:74
msgid "Fedora Eclipse"
msgstr "Fedora Eclipse"

#: ../comps-f32.xml.in.h:77 ../comps-f33.xml.in.h:75 ../comps-f34.xml.in.h:75
msgid "Integrated Development Environments based on Eclipse."
msgstr "Eclipse негізіндегі интеграцияланған әзірлеу орталары."

#: ../comps-f32.xml.in.h:78 ../comps-f33.xml.in.h:76 ../comps-f34.xml.in.h:76
msgid "Editors"
