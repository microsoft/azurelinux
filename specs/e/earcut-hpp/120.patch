---
 include/mapbox/earcut.hpp | 1 +
 1 file changed, 1 insertion(+)

diff --git a/include/mapbox/earcut.hpp b/include/mapbox/earcut.hpp
index b98508f..fd33814 100644
--- a/include/mapbox/earcut.hpp
+++ b/include/mapbox/earcut.hpp
@@ -4,6 +4,7 @@
 #include <cassert>
 #include <cmath>
 #include <cstddef>
+#include <cstdint>
 #include <limits>
 #include <memory>
 #include <utility>
