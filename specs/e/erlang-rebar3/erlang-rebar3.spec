%{_datadir}/erlang/lib/%{realname}-%{version}
%{_mandir}/man1/%{realname}3.1*
%{bash_completions_dir}/%{realname}3
%{fish_completions_dir}/%{realname}3.fish
%{zsh_completions_dir}/_%{realname}3

