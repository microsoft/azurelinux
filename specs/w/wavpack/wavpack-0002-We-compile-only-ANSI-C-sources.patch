From: Peter Lemenkov <lemenkov@gmail.com>
Date: Fri, 25 Oct 2024 19:15:33 +0300
Subject: [PATCH] We compile only ANSI C sources

Signed-off-by: Peter Lemenkov <lemenkov@gmail.com>

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 36bf4f8..82f7173 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,6 +1,6 @@
 cmake_minimum_required(VERSION 3.2...3.10)
 
-project(WavPack VERSION 5.8.1)
+project(WavPack VERSION 5.8.1 LANGUAGES C)
 
 file(READ "${CMAKE_CURRENT_SOURCE_DIR}/configure.ac" CONFIGURE_AC)
 string(REGEX MATCH "LT_CURRENT=([0-9]+)" LT_CURRENT "${CONFIGURE_AC}")
