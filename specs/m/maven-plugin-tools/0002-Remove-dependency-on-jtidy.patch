-        } catch (IOException e) {
-            throw new RuntimeException(e);
-        }
+        HTMLEditorKit.ParserCallback htmlCallback = new MojoParserCallback(sb);
+
+        try {
+            parser.parse(new StringReader(html), htmlCallback, true);
+        } catch (IOException e) {
+            throw new RuntimeException(e);
+        }
 
         return sb.toString().replace('\"', '\''); // for CDATA
     }
