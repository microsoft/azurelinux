+++ b/source/gitlab/gitlab.go
@@ -52,29 +52,26 @@ func (g *Gitlab) Open(url string) (source.Driver, error) {
 		return nil, ErrNoUserInfo
 	}
 
+	if u.Host == "" {
+		return nil, ErrInvalidHost
+	}
+
 	password, ok := u.User.Password()
 	if !ok {
 		return nil, ErrNoAccessToken
 	}
 
+	client, err := gitlab.NewClient(password, gitlab.WithBaseURL(u.String()))
+	if err != nil {
+		return nil, err
+	}
+
 	gn := &Gitlab{
-		client:     gitlab.NewClient(nil, password),
+		client:     client,
 		url:        url,
 		migrations: source.NewMigrations(),
 	}
 
