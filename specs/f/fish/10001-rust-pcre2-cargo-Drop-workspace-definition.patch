 1 file changed, 3 deletions(-)

diff --git a/third-party-forks/rust-pcre2/Cargo.toml b/third-party-forks/rust-pcre2/Cargo.toml
index cc35675..f5245be 100644
--- a/third-party-forks/rust-pcre2/Cargo.toml
+++ b/third-party-forks/rust-pcre2/Cargo.toml
@@ -12,9 +12,6 @@ license = "Unlicense OR MIT"
 categories = ["text-processing"]
 edition = "2021"
 
-[workspace]
-members = ["pcre2-sys"]
-
 [dependencies]
 libc = "0.2.146"
 log = "0.4.19"
