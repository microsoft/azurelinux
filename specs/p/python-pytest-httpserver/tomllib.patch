From 162c6fae030e797167c3edd07eeccb3ba8bb707a Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Miro=20Hron=C4=8Dok?= <miro@hroncok.cz>
Date: Thu, 7 Nov 2024 09:52:44 +0100
Subject: [PATCH] Where available, use tomllib from the standard library

Fallback to tomli, which is the same project,
rather than toml which wasn't updated for a while.
---
 pyproject.toml        | 6 ++----
 tests/test_release.py | 9 ++++++---
 2 files changed, 8 insertions(+), 7 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 01e1275..7867420 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -48,8 +48,7 @@ types-requests = "^2.28.9"
 pytest = "^7.1.3"
 pytest-cov = ">=3,<5"
 coverage = ">=6.4.4,<8.0.0"
-types-toml = "^0.10.8"
-toml = "^0.10.2"
+tomli = { version = "*", markers = "python_version < '3.11'"}
 black = "^23.1.0"
 
 
@@ -72,8 +71,7 @@ requests = "^2.28.1"
 mypy = "^0.971"
 types-requests = "^2.28.9"
 pre-commit = "^2.20.0"
-types-toml = "^0.10.8"
-toml = "^0.10.2"
+tomli = { version = "*", markers = "python_version < '3.11'"}
 
 [build-system]
 requires = ["poetry-core>=1.0.0"]
diff --git a/tests/test_release.py b/tests/test_release.py
index e3bc6b1..bcbb0ce 100644
--- a/tests/test_release.py
+++ b/tests/test_release.py
@@ -13,7 +13,10 @@ from typing import Iterable
 from typing import Tuple
 
 import pytest
-import toml
+try:
+    import tomllib
+except ImportError:
+    import tomli as tomllib
 
 pytestmark = pytest.mark.release
 
@@ -29,8 +32,8 @@ def pyproject_path() -> Path:
 @pytest.fixture(scope="session")
 def pyproject(pyproject_path: Path):
     assert pyproject_path.is_file()
-    with pyproject_path.open() as infile:
-        pyproject = toml.load(infile)
+    with pyproject_path.open("rb") as infile:
+        pyproject = tomllib.load(infile)
     return pyproject
 
 
-- 
2.47.0

