From ff2c035810fd7f8fa7500e6ba5e0cde5814fe14e Mon Sep 17 00:00:00 2001
From: "Benjamin A. Beasley" <code@musicinmybrain.net>
Date: Thu, 1 Feb 2024 08:59:28 -0500
Subject: [PATCH 1/2] Downstream-only: patch out coverage analysis

https://docs.fedoraproject.org/en-US/packaging-guidelines/Python/#_linters
---
 pyproject.toml | 2 +-
 tox.ini        | 3 +--
 2 files changed, 2 insertions(+), 3 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 0535a7a..7a89c9d 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -73,7 +73,7 @@ module =["trio.*"]
 ignore_missing_imports = true
 
 [tool.pytest.ini_options]
-addopts = "--no-cov-on-fail --showlocals --strict-markers"
+addopts = "--showlocals --strict-markers"
 asyncio_default_fixture_loop_scope = "session"
 asyncio_mode = "auto"
 testpaths = ["tests"]
diff --git a/tox.ini b/tox.ini
index bc05bf4..80acbea 100644
--- a/tox.ini
+++ b/tox.ini
@@ -5,10 +5,9 @@ isolated_build = True
 [testenv]
 deps =
     pytest
-    pytest-cov
     pytest-sugar
     pytest-trio
-commands = pytest --cov=quart_trio {posargs}
+commands = pytest {posargs}
 
 [testenv:docs]
 basepython = python3.13
-- 
2.50.1

