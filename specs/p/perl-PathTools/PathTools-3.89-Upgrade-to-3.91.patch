diff --git a/Cwd.pm b/Cwd.pm
index dbf08a6..549aa94 100644
--- a/Cwd.pm
+++ b/Cwd.pm
@@ -3,7 +3,7 @@ use strict;
 use Exporter;
 
 
-our $VERSION = '3.89';
+our $VERSION = '3.91';
 my $xs_version = $VERSION;
 $VERSION =~ tr/_//d;
 
diff --git a/Cwd.xs b/Cwd.xs
index ca8639d..bca575c 100644
--- a/Cwd.xs
+++ b/Cwd.xs
@@ -292,7 +292,6 @@ return FALSE
