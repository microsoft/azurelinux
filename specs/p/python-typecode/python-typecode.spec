%global pypi_name typecode

Name:           python-%{pypi_name}
Version:        30.0.2
Release:        %autorelease
Summary:        Comprehensive filetype and mimetype detection

# Apache-2.0: main library
# Apache-2.0 AND MIT : src/typecode/magic2.py
# BSD-2-Clause-Views AND MIT:
