+++ b/openid/test/test_parsehtml.py
@@ -74,7 +74,8 @@ def getCases(test_files=default_test_files):
     cases = []
     for filename in test_files:
         test_num = 0
-        data = open(filename).read()
+        with open(filename) as data_file:
