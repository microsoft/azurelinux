     "pytest-asyncio>=0.17",
     "pytest>=3.10",
-    "sphinx<=4.3.2",  # `docutils` from sphinx is used in tests
+    "sphinx",  # `docutils` from sphinx is used in tests
 ]
 
 EXTRAS_DEV_DOCS = [
