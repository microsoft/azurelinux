 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/setup.py b/setup.py
index cc846e4..225b267 100755
--- a/setup.py
+++ b/setup.py
@@ -12,7 +12,7 @@ EXTRAS_DEV_LINT = [
