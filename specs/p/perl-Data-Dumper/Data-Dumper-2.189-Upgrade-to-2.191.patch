@@ -1701,13 +1703,13 @@ Data_Dumper__vstring(sv)
 	CODE:
 	{
 #ifdef SvVOK
-	    const MAGIC *mg;
-	    RETVAL =
-		SvMAGICAL(sv) && (mg = mg_find(sv, 'V'))
-		 ? newSVpvn((const char *)mg->mg_ptr, mg->mg_len)
-		 : &PL_sv_undef;
-#else
-	    RETVAL = &PL_sv_undef;
+	    if(SvVOK(sv)) {
+		STRLEN vstr_len;
+		const char *vstr_pv = SvVSTRING(sv, vstr_len);
+		RETVAL = newSVpvn(vstr_pv, vstr_len);
+	    }
+	    else
 #endif
