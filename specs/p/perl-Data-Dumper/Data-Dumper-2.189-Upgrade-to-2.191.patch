 #  endif
 	    if (!sv_eq(vecsv, val)) goto integer_came_from_string;
 # endif
-	    sv_catpvn(retval, (const char *)mg->mg_ptr, mg->mg_len);
+	    sv_catpvn(retval, vstr_pv, vstr_len);
 	}
