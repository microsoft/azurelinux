+
+int				      // O - success 0/error 1
+hash_data(unsigned char *data,	      // I - Data to hash
+	  size_t	datalen,      // I - Length of data
+	  char		*hash_string, // O - Hexadecimal hashed string
+	  size_t	string_len)   // I - Length of hexadecimal hashed string
