Do not call the undeclared exit function.  Implicit function
declarations have been removed from the C language in 1999.
Future compilers will likely reject them by default.

No need to upstream this because it is purely in autoconf-generated
code, so it will go away when re-running autoconf, without any
package-specific changes.

diff --git a/configure b/configure
index b6d8253f53bb4b3c..e88533902e5ceb33 100755
--- a/configure
+++ b/configure
@@ -2680,7 +2680,7 @@ if { (eval echo "$as_me:$LINENO: \"$ac_compile\"") >&5
   echo "$as_me:$LINENO: \$? = $ac_status" >&5
   (exit $ac_status); }; }; then
   for ac_declaration in \
-   '' \
+   '#include <stdlib.h>' \
    'extern "C" void std::exit (int) throw (); using std::exit;' \
    'extern "C" void std::exit (int); using std::exit;' \
    'extern "C" void exit (int) throw ();' \
@@ -6384,8 +6384,8 @@ main ()
   for (i = 0; i < 256; i++)
     if (XOR (islower (i), ISLOWER (i))
 	|| toupper (i) != TOUPPER (i))
-      exit(2);
-  exit (0);
+      return 2;
+  return 0;
 }
 _ACEOF
 rm -f conftest$ac_exeext
