+                    pagedresults_free_one(pb_conn, operation, PR_LOCKED, pr_idx);
                 }
-                pagedresults_unlock(pb_conn, pr_idx);
+                pthread_mutex_unlock(pagedresults_mutex);
                 if (next_be) {
                     /* no more entries, but at least another backend */
