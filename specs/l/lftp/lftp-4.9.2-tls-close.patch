-void lftp_ssl_openssl::shutdown()
+int lftp_ssl_openssl::shutdown()
 {
-   if(handshake_done)
-      SSL_shutdown(ssl);
+   int res;
+   if(handshake_done) {
+      res = SSL_shutdown(ssl);
+      if (res == 1) {
+         goodbye_done = true;
+         return DONE;
+      } else if (res == 0) {
+         return RETRY;
+      }
+      fatal=check_fatal(res);
+      set_error("SSL_shutdown",strerror());
+      return ERROR;
+   }
+   goodbye_done = true;
+   return DONE;
 }
 lftp_ssl_openssl::~lftp_ssl_openssl()
 {
