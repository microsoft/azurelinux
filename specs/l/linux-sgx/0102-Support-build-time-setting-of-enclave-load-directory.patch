     {
@@ -362,4 +370,4 @@ quote3_error_t ecall_authenticate_policy_owner(sgx_enclave_id_t eid,
             retval = SGX_QL_ERROR_UNEXPECTED;
     }
     return retval;
-}
\ No newline at end of file
+}
