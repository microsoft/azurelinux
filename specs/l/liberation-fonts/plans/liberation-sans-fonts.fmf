summary: Fonts related tests
discover:
    how: fmf
    url: https://src.fedoraproject.org/tests/fonts
prepare:
    name: tmt
    how: install
    package: liberation-sans-fonts
execute:
    how: tmt
environment:
    PACKAGE: liberation-sans-fonts
    FONT_ALIAS: Arial
    FONT_FAMILY: Liberation Sans
    FONT_LANG: en
