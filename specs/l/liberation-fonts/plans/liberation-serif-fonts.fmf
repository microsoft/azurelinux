summary: Fonts related tests
discover:
    how: fmf
    url: https://src.fedoraproject.org/tests/fonts
prepare:
    name: tmt
    how: install
    package: liberation-serif-fonts
execute:
    how: tmt
environment:
    PACKAGE: liberation-serif-fonts
    FONT_ALIAS: Times New Roman
    FONT_FAMILY: Liberation Serif
    FONT_LANG: en
