  -DSDLIMAGE_XV=ON

%cmake_build

%install
%cmake_install

# s390x fails on WEBP animations:
# ERROR: 01/23/26 10:14:24: Frame data mismatch at index 1. Expected (256, 256, 20), Got (256, 256, 40)
