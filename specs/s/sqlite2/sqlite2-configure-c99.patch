Avoid calling the undeclared exit function.  Implicit function
declarations have been removed from C99, and future compilers are
likely to reject this code by default.

diff --git a/configure b/configure
index f0759bb519a82537..463add383afd84ef 100755
--- a/configure
+++ b/configure
@@ -2459,7 +2459,7 @@ if { (eval echo "$as_me:$LINENO: \"$ac_compile\"") >&5
   echo "$as_me:$LINENO: \$? = $ac_status" >&5
   (exit $ac_status); }; }; then
   for ac_declaration in \
-   '' \
+   '#include <stdlib.h>' \
    'extern "C" void std::exit (int) throw (); using std::exit;' \
    'extern "C" void std::exit (int); using std::exit;' \
    'extern "C" void exit (int) throw ();' \
@@ -3570,8 +3570,8 @@ main ()
