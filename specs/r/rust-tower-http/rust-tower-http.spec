%prep
%autosetup -n %{crate}-%{version} -p1
%cargo_prep
# Adjust include_bytes!("../[…]/README.md") to work out of tree in tests.
# (The tests in question may be disabled, but this keeps them from failing
# to compile.)
sed -r -i 's@(include_bytes!\(".*)\.\./(README\.md")@\1\2@' \
    src/services/fs/serve_file.rs \
    src/services/fs/serve_dir/tests.rs

%generate_buildrequires
%cargo_generate_buildrequires -f full

%build
%cargo_build -f full

%install
%cargo_install -f full

%if %{with check}
%check
# * Many serve_dir/serve_file tests require files from test_files, which are not
#   included in the crate, or make path assumptions that only hold in the
#   workspace.
%{cargo_test -f full -- -- %{shrink:
    --skip services::fs::serve_dir::
    --skip services::fs::serve_file::
}}
%endif

