From 8650386047c46ef098b9970cba88e1ebbc9afa2a Mon Sep 17 00:00:00 2001
From: Fabio Valentini <decathorpe@gmail.com>
Date: Mon, 18 Aug 2025 13:46:37 +0200
Subject: [PATCH] Drop deny(warnings) from doctests

---
 src/lib.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/lib.rs b/src/lib.rs
index 18c5edb..0301da0 100644
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -170,7 +170,7 @@ missing_debug_implementations,
 #![cfg_attr(docsrs, feature(doc_cfg))]
 #![doc(test(
 no_crate_inject,
-attr(deny(warnings/*, rust_2018_idioms*/), allow(dead_code, unused_variables))
+attr(allow(dead_code, unused_variables))
 ))]
 #![cfg_attr(not(feature = "std"), no_std)]
 
