%prep
%autosetup -n %{crate}-%{version} -p1
# Drop dev-dependency hifitime: not packaged, and only for doctests
tomcli set Cargo.toml del \
    "target.'cfg(not(target_family = \"wasm\"))'.dev-dependencies.hifitime"
