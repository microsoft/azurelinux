     {
         let wrapped = self.build(future);
 
-        kv_log_macro::trace!("spawn", {
-            task_id: wrapped.tag.id().0,
-            parent_task_id: TaskLocalsWrapper::get_current(|t| t.id().0).unwrap_or(0),
-        });
