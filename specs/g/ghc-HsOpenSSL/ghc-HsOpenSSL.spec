%bcond tests 1

Name:           ghc-%{pkg_name}
Version:        0.11.7.9
Release:        %autorelease
Summary:        Partial OpenSSL binding for Haskell

# see also the ChangeLog entry for 2013-11-07
License:        CC0-1.0
URL:            https://hackage.haskell.org/package/HsOpenSSL
