# https://pagure.io/golist
%global goipath         pagure.io/golist
%global forgeurl        https://pagure.io/golist
Version:                0.10.4

%gometa

%global common_description %{expand:
A tool to analyse the properties of a Go (Golang) codebase.}

%global godocs          NEWS.md README.md
%global golicenses      LICENSE

Name:           golist
Release:        %autorelease
Summary:        A tool to analyse the properties of a Go (Golang) codebase

License:        BSD-3-Clause
URL:            %{gourl}
Source:         https://pagure.io/golist/archive/v%{version}/golist-%{version}.tar.gz

BuildRequires:  golang(github.com/urfave/cli)

%description %{common_description}

%prep
%goprep
%autopatch -p1

%build
for cmd in cmd/* ; do
  %gobuild -o %{gobuilddir}/bin/$(basename $cmd) %{goipath}/$cmd
done

%install
install -m 0755 -vd                     %{buildroot}%{_bindir}
install -m 0755 -vp %{gobuilddir}/bin/* %{buildroot}%{_bindir}/

%if %{with check}
%check
%gocheck
%endif

%files
%doc README.md NEWS.md
%license LICENSE
%{_bindir}/golist

