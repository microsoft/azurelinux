-      fe.symtab = sf->symtab;
+      fe.set_symtab (sf->symtab);
     }
 }
 
@@ -16879,7 +16882,7 @@ new_symbol (struct die_info *die, struct type *type, struct dwarf2_cu *cu,
 	      if (fe == NULL)
