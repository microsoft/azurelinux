summary: Fonts related tests
discover:
    how: fmf
    url: https://src.fedoraproject.org/tests/fonts
prepare:
    name: tmt
    how: install
    package: google-droid-sans-mono-fonts
execute:
    how: tmt
environment:
    PACKAGE: google-droid-sans-mono-fonts
    FONT_ALIAS: monospace
    FONT_FAMILY: Droid Sans Mono
