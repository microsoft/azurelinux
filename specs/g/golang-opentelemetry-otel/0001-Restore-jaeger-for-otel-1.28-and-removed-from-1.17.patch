+	// 106 is the serialized size of a span with default values.
+	maxSize := 106
+
+	largeSpans := tracetest.SpanStubs{generateALargeSpan(), {}}.Snapshots()
+	normalSpans := tracetest.SpanStubs{{}, {}}.Snapshots()
