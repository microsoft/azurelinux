summary: Fonts related tests
discover:
    how: fmf
    url: https://src.fedoraproject.org/tests/fonts
prepare:
    name: tmt
    how: install
    package: dejavu-sans-mono-fonts
execute:
    how: tmt
environment:
    PACKAGE: dejavu-sans-mono-fonts
    FONT_ALIAS: monospace
    FONT_FAMILY: DejaVu Sans Mono
