Signed-off-by: Samuel Cabrero <scabrero@suse.de>
---
 library/adconn.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/library/adconn.c b/library/adconn.c
index c714169..77c09c4 100644
--- a/library/adconn.c
+++ b/library/adconn.c
@@ -868,6 +868,7 @@ connect_to_address (const char *host,
 					break;
 				}
 			}
+			break;
 		}
 	}
 
