+int lc_dilithium_65_ed448_sign(struct lc_dilithium_65_ed448_sig *sig,
+                               const uint8_t *m, size_t mlen,
+                               const struct lc_dilithium_65_ed448_sk *sk,
+                               struct lc_rng_ctx *rng_ctx);
