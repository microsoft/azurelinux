+extern "C" {
+#endif
+
+/**
+ * @brief Is FIPS 140 Mode enabled?
+ *
+ * return 0 == false, 1 == true
+ */
+int fips140_mode_enabled(void);
+
+#define FIPS140_PCT_LOOP(func)          \
+    if (fips140_mode_enabled()) {       \
+        unsigned int __i;               \
+        int __ret;                      \
+                                        \
+        for (__i = 0; __i < 5; __i++) { \
+            __ret = func;               \
+            if (!__ret)                 \
+                return __ret;           \
+        }                               \
+        assert(0);                      \
+    }
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* FIPS_MODE_H */
