+process_versions()
+{
+    echo "process_version($3)" >&2
+    local -n vers=$1
+    local -n mods=$2
+    declare -p vers
+    declare -p mods 
+    vers=()
+    mods=()
+    for i in ${3//;/ }
+    do
+        ver=${i%%:*}
+        mod=${i##*:}
+        echo "spec=/$i/ ver=/$ver/ mod=/$mod/" >&2
+        if [[ "$ver" = "" || "$mod" = "" ]]; then
+            echo "invalid version spec \"$i\"" >&2
+            return 1
+        fi
+        vers+=($ver)
+        mods+=($mod)
+    done
+    return 0
+}
