+                                                 &sk->key.sk_87, rng_ctx);
+#else
+            return -EOPNOTSUPP;
+#endif
+        case LC_DILITHIUM_65:
+#ifdef LC_DILITHIUM_65_ENABLED
+            pk->dilithium_type = dilithium_type;
+            sk->dilithium_type = dilithium_type;
