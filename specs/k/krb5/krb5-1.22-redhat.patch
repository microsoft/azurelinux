index 648dc2ed99..abc6806ca1 100644
--- a/doc/appdev/refs/api/index.rst
+++ b/doc/appdev/refs/api/index.rst
@@ -227,6 +227,7 @@ Rarely used public interfaces
    krb5_is_referral_realm.rst
