diff -up kbd-2.7-rc1/src/vlock/auth.c.orig kbd-2.7-rc1/src/vlock/auth.c
--- kbd-2.7-rc1/src/vlock/auth.c.orig	2024-10-09 15:14:58.000000000 +0200
