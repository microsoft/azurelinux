-    }
     if (!single) {
         /* execute config component */
         if (g_strcmp0 (config, "default") == 0) {
diff --git a/bus/services/org.freedesktop.IBus.session.GNOME.service.in b/bus/services/org.freedesktop.IBus.session.GNOME.service.in
