     if (destroy_data.window)
+#if GTK_CHECK_VERSION (4, 0, 0)
 	gtk_window_destroy (GTK_WINDOW (destroy_data.window));
+#else
+        gtk_widget_destroy (destroy_data.window);
+#endif
     close (m_pipe_engine[0]);
     close (m_pipe_engine[1]);
 }
